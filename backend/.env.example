# ============================================
# OLIVEIRA APPLY AI — Backend Environment
# ============================================

# App
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oliveira_apply_ai"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption (for LinkedIn passwords)
ENCRYPTION_KEY="your-32-char-encryption-key-here!!"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Ollama (optional - local AI)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
USE_OLLAMA=false

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# Frontend
FRONTEND_URL="http://localhost:3000"

# Automation
AUTOMATION_CONCURRENCY=3
HEADLESS_BROWSER=true

# Email (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="noreply@oliveira-apply.ai"
